model Tournament {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String?          @map("organization_id") @db.Uuid
  createdBy      String           @map("created_by") @db.Uuid
  name        String
  format      TournamentFormat
  category    String
  startDate   DateTime         @map("start_date") @db.Date
  endDate     DateTime         @map("end_date") @db.Date
  status      TournamentStatus @default(draft)
  maxEntries  Int?             @map("max_entries")
  entryFee         Decimal          @default(0) @map("entry_fee") @db.Decimal(10, 2)
  requiresPartner  Boolean          @default(false) @map("requires_partner")
  numCourts        Int?             @map("num_courts")
  tournamentDate   DateTime?        @map("tournament_date") @db.Date
  startTime        DateTime?        @map("start_time") @db.Time(6)
  endTime          DateTime?        @map("end_time") @db.Time(6)
  courtCostTotal   Decimal?         @default(0) @map("court_cost_total") @db.Decimal(10, 2)
  description String?
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization   Organization?     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creatorProfile Profile           @relation(fields: [createdBy], references: [id])
  entries        TournamentEntry[]
  matches        TournamentMatch[]

  @@map("tournaments")
}

model TournamentEntry {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tournamentId String      @map("tournament_id") @db.Uuid
  player1Id    String      @map("player1_id") @db.Uuid
  player2Id    String?     @map("player2_id") @db.Uuid
  registeredBy String      @map("registered_by") @db.Uuid
  status       EntryStatus @default(pending)
  isRoundPair  Boolean     @default(false) @map("is_round_pair")
  registeredAt DateTime    @default(now()) @map("registered_at") @db.Timestamptz(6)

  tournament      Tournament  @relation(fields: [tournamentId], references: [id])
  player1         Profile     @relation("Player1Entries", fields: [player1Id], references: [id])
  player2         Profile?    @relation("Player2Entries", fields: [player2Id], references: [id])
  registrar       Profile     @relation("RegisteredByEntries", fields: [registeredBy], references: [id])
  matchesAsEntry1 TournamentMatch[] @relation("Entry1Matches")
  matchesAsEntry2 TournamentMatch[] @relation("Entry2Matches")
  matchesAsWinner TournamentMatch[] @relation("WinnerMatches")

  @@map("tournament_entries")
}

model TournamentMatch {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tournamentId  String      @map("tournament_id") @db.Uuid
  entry1Id      String      @map("entry1_id") @db.Uuid
  entry2Id      String?     @map("entry2_id") @db.Uuid
  round         String
  roundNumber   Int?        @map("round_number")
  courtNumber   Int?        @map("court_number")
  scheduledAt   DateTime?   @map("scheduled_at") @db.Timestamptz(6)
  courtId       String?     @map("court_id") @db.Uuid
  scoreEntry1   String?     @map("score_entry1")
  scoreEntry2   String?     @map("score_entry2")
  winnerEntryId String?     @map("winner_entry_id") @db.Uuid
  status        MatchStatus @default(scheduled)
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  tournament Tournament      @relation(fields: [tournamentId], references: [id])
  entry1     TournamentEntry @relation("Entry1Matches", fields: [entry1Id], references: [id])
  entry2     TournamentEntry? @relation("Entry2Matches", fields: [entry2Id], references: [id])
  court      Court?          @relation(fields: [courtId], references: [id])
  winner     TournamentEntry? @relation("WinnerMatches", fields: [winnerEntryId], references: [id])

  @@map("tournament_matches")
}

