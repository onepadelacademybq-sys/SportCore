  schedules    GroupSchedule[]
  members      GroupMember[]
  groupPayments GroupPayment[]
  bookings     Booking[]
  mesocycleAssignments MesocycleAssignment[]
  announcements Announcement[]
  financialTransactions FinancialTransaction[]

  @@map("training_groups")
}

model GroupSchedule {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  groupId   String   @map("group_id") @db.Uuid
  dayOfWeek Int      @map("day_of_week")
  startTime DateTime @map("start_time") @db.Time(6)
  endTime   DateTime @map("end_time") @db.Time(6)

  group TrainingGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@map("group_schedules")
}

model GroupMember {
  id                   String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  groupId              String                     @map("group_id") @db.Uuid
  playerId             String                     @map("player_id") @db.Uuid
  status               GroupMemberStatus          @default(waitlist)
  paymentStatus        GroupMemberPaymentStatus?  @map("payment_status")
  paymentProofUrl      String?                    @map("payment_proof_url")
  monthlyFeePaidUntil  DateTime?                  @map("monthly_fee_paid_until") @db.Date
  joinedAt             DateTime                   @default(now()) @map("joined_at") @db.Timestamptz(6)
  leftAt               DateTime?                  @map("left_at") @db.Timestamptz(6)
