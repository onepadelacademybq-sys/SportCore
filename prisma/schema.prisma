  group  TrainingGroup @relation(fields: [groupId], references: [id])
  player Profile       @relation(fields: [playerId], references: [id])

  @@unique([groupId, playerId])
  @@map("group_members")
}

model GroupPayment {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  groupId     String             @map("group_id") @db.Uuid
  playerId    String             @map("player_id") @db.Uuid
  periodYear  Int                @map("period_year")
  periodMonth Int                @map("period_month")
  amountDue   Decimal            @map("amount_due") @db.Decimal(10, 2)
  amountPaid  Decimal            @default(0) @map("amount_paid") @db.Decimal(10, 2)
  status      GroupPaymentStatus @default(pending)
  paymentDate DateTime?          @map("payment_date") @db.Date
  paymentId   String?            @map("payment_id") @db.Uuid
