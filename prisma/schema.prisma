// One Padel Academy — Prisma Schema
// Generado desde DATABASE.md
// Prisma 7 — provider: prisma-client (nuevo generator)
// URLs de conexión en prisma.config.ts (no en este archivo)

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  admin
  coach
  player
}

enum OrgPlan {
  starter
  pro
  enterprise
}

enum OrgStatus {
  trialing
  active
  suspended
  cancelled
}

enum PadelLevel {
  quinta_masculino   @map("5ta_masculino")
  sexta_masculino    @map("6ta_masculino")
  septima_masculino  @map("7ma_masculino")
  femenino_d
  femenino_c
  juvenil_s18
  juvenil_s16
  juvenil_s14
  prejuvenil
  baby_padel
}

enum CourtType {
  indoor
  outdoor
}

enum CourtSurface {
  cesped_artificial
  moqueta
  cristal
  hormigon
}

enum ResourceType {
  cancha
  campo
  carril
  pista
  sala
}

enum CourtStatus {
  active
  maintenance
  closed
}

enum BookingStatus {
  pending    // solicitada
  paid       // jugador subió comprobante
  confirmed  // admin verificó y confirmó
  cancelled
  completed
  no_show
}

enum ExerciseTheme {
  calentamiento
  tecnica
  tactica
  fisico
  mental
  vuelta_a_la_calma
}

enum MesocycleStatus {
  draft
  active
  completed
  archived
}

enum SessionBlockType {
  calentamiento
  central
  vuelta_a_la_calma
}

enum SessionStatus {
  scheduled
  completed
  cancelled
}

enum AttendanceStatus {
  present
  absent
  justified
}

enum GroupMemberStatus {
  active
  waitlist
  inactive
  pending_payment
}

enum GroupMemberPaymentStatus {
  pending
  paid
  confirmed
}

enum EvalCategory {
  tecnica
  tactica
  fisico
  mental
}

enum EvalLevel {
  C
  B
  A
  Elite
}

enum KpiScoreType {
  scale
  percentage
  numeric
}

enum TournamentFormat {
  eliminatoria
  grupos
  grupos_y_eliminatoria
  americano_individual
  americano_parejas
  americano_rey_pista
  super_8
  americano_mixto
}

enum TournamentStatus {
  draft
  open
  in_progress
  completed
  cancelled
}

enum EntryStatus {
  pending
  confirmed
  eliminated
  withdrawn
}

enum MatchStatus {
  scheduled
  in_progress
  completed
  cancelled
}

enum PaymentType {
  subscription
  booking
  group_fee
  tournament_entry
  other
}

enum PaymentMethod {
  stripe
  cash
  transfer
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum InvoiceStatus {
  draft
  sent
  paid
  cancelled
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  cancelled
}

enum SubscriptionPlan {
  monthly
  quarterly
  annual
}

enum ExpenseCategory {
  equipment
  maintenance
  utilities
  salaries
  marketing
  other
}

enum NotificationType {
  booking_confirmed
  booking_reminder
  booking_cancelled
  session_assigned
  session_reminder
  session_cancelled
  evaluation_ready
  payment_processed
  payment_failed
  payment_overdue
  tournament_update
  group_change
  announcement
}

// ─────────────────────────────────────────────
// CRM + WHATSAPP ENUMS
// ─────────────────────────────────────────────

enum LeadStatus {
  new
  contacted
  trial_scheduled
  trial_done
  converted
  lost
}

enum LeadSource {
  web_form
  instagram
  facebook
  referral
  walk_in
  whatsapp
  other
}

enum InteractionType {
  whatsapp_sent
  whatsapp_received
  call
  email
  note
  trial_class
  follow_up
}

enum RetentionStatus {
  active
  at_risk
  losing
  churned
}

enum WaMessageStatus {
  queued
  sent
  delivered
  read
  failed
}

enum GroupStatus {
  active
  paused
  closed
}

enum GroupPaymentStatus {
  pending
  paid
  partial
  overdue
}

// ─────────────────────────────────────────────
// MÓDULO 0 — Multi-tenancy (Organization)
// ─────────────────────────────────────────────

model Organization {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  slug             String    @unique
  sport            String    @default("general")
  plan             OrgPlan   @default(starter)
  status           OrgStatus @default(trialing)
  stripeCustomerId String?   @unique @map("stripe_customer_id")
  stripeSubId      String?   @unique @map("stripe_sub_id")
  planLimits       Json      @default("{\"max_resources\":6,\"max_members\":100,\"max_coaches\":3}") @map("plan_limits")
  planStartedAt    DateTime? @map("plan_started_at") @db.Timestamptz(6)
  planExpiresAt    DateTime? @map("plan_expires_at") @db.Timestamptz(6)
  trialEndsAt      DateTime? @map("trial_ends_at") @db.Timestamptz(6)
  terminology      Json      @default("{\"resource\":\"Cancha\",\"coach\":\"Entrenador\",\"player\":\"Jugador\"}") @map("terminology")
  logoUrl          String?   @map("logo_url")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  profiles             Profile[]
  courts               Court[]
  bookings             Booking[]
  trainingGroups       TrainingGroup[]
  mesocycles           Mesocycle[]
  macrocycles          Macrocycle[]
  exercises            Exercise[]
  evaluations          Evaluation[]
  evaluationTemplates  EvaluationTemplate[]
  tournaments          Tournament[]
  financialTransactions FinancialTransaction[]
  bankAccounts         BankAccount[]
  invoices             Invoice[]
  payments             Payment[]
  expenses             Expense[]
  leads                Lead[]
  announcements        Announcement[]
  equipment            Equipment[]
  academySettings      AcademySetting?

  @@map("organizations")
}

// ─────────────────────────────────────────────
// MÓDULO 1 — Usuarios
// ─────────────────────────────────────────────

model Profile {
  id               String     @id @db.Uuid
  organizationId   String?    @map("organization_id") @db.Uuid
  email            String     @unique
  fullName         String     @map("full_name")
  avatarUrl        String?    @map("avatar_url")
  role             UserRole
  phone            String?
  whatsappPhone    String?    @map("whatsapp_phone")
  documentId       String?    @map("document_id")
  dateOfBirth      DateTime?  @map("date_of_birth") @db.Date
  address          String?
  padelLevel       PadelLevel? @map("padel_level")
  stripeCustomerId String?    @unique @map("stripe_customer_id")
  isActive         Boolean    @default(true) @map("is_active")
  createdAt        DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization     Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  // Módulo 13
  coachProfile     CoachProfile?

  // Módulo 2
  bookingsAsPlayer  Booking[]           @relation("PlayerBookings")
  bookingsAsCoach   Booking[]           @relation("CoachBookings")
  bookingsCreated   Booking[]           @relation("CreatedByBookings")
  bookingWaitlist   BookingWaitlist[]

  // Módulo 11
  exercisesCreated  Exercise[]
  exerciseFavorites ExerciseFavorite[]

  // Módulo 4
  mesocyclesCreated          Mesocycle[]
  macrocyclesCreated         Macrocycle[]
  mesocycleAssignmentsPlayer MesocycleAssignment[] @relation("PlayerAssignments")
  mesocycleAssignmentsBy     MesocycleAssignment[] @relation("AssignedByAssignments")
  sessionAttendance          SessionAttendance[]

  // Módulo 12
  groupsAsCoach    TrainingGroup[]
  groupMemberships GroupMember[]
  groupPayments    GroupPayment[]

  // Módulo 5
  evaluationTemplatesCreated EvaluationTemplate[]
  evaluationsAsPlayer        Evaluation[]         @relation("PlayerEvaluations")
  evaluationsAsCoach         Evaluation[]         @relation("CoachEvaluations")

  // Módulo 6
  tournamentsCreated            Tournament[]
  tournamentEntriesAsPlayer1    TournamentEntry[] @relation("Player1Entries")
  tournamentEntriesAsPlayer2    TournamentEntry[] @relation("Player2Entries")
  tournamentEntriesRegisteredBy TournamentEntry[] @relation("RegisteredByEntries")

  // Módulo 7
  invoices      Invoice[]
  payments      Payment[]
  subscriptions Subscription[]
  expenses      Expense[]
  financialTransactionsCreated FinancialTransaction[]

  // Módulo 8
  notifications           Notification[]
  notificationPreferences NotificationPreference?
  announcementsCreated    Announcement[]

  // Módulo 13
  coachRatingsGiven CoachRating[]

  // E-wallet
  classWallet        ClassWallet?
  walletTransactions WalletTransaction[]
  guardianProfile    GuardianProfile?

  // CRM
  leadsConverted     Lead[]          @relation("LeadProfile")
  leadsAssigned      Lead[]          @relation("LeadAssignee")
  interactions       Interaction[]   @relation("InteractionProfile")
  interactionsCreated Interaction[]  @relation("InteractionCreator")
  retentionScore     RetentionScore?

  @@map("profiles")
}

// ─────────────────────────────────────────────
// MÓDULO — Menores de edad
// ─────────────────────────────────────────────

model GuardianProfile {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  minorId              String   @unique @map("minor_id") @db.Uuid
  guardianName         String   @map("guardian_name")
  guardianDocument     String   @map("guardian_document")
  guardianPhone        String   @map("guardian_phone")
  guardianEmail        String   @map("guardian_email")
  guardianRelationship String   @map("guardian_relationship")
  consentAccepted      Boolean  @default(false) @map("consent_accepted")
  consentDate          DateTime @default(now()) @map("consent_date") @db.Timestamptz(6)
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  minor                Profile  @relation(fields: [minorId], references: [id], onDelete: Cascade)

  @@map("guardian_profiles")
}

// ─────────────────────────────────────────────
// E-WALLET DE CLASES
// ─────────────────────────────────────────────

model ClassWallet {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  playerId         String   @unique @map("player_id") @db.Uuid
  totalClasses     Int      @default(0) @map("total_classes")
  usedClasses      Int      @default(0) @map("used_classes")
  availableClasses Int      @default(dbgenerated("(total_classes - used_classes)")) @map("available_classes")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  player Profile @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@map("class_wallet")
}

model WalletTransaction {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  playerId    String   @map("player_id") @db.Uuid
  bookingId   String?  @map("booking_id") @db.Uuid
  type        String
  classes     Int
  description String
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  player  Profile  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@map("wallet_transactions")
}

// ─────────────────────────────────────────────
// MÓDULO 3 — Instalaciones
// ─────────────────────────────────────────────

model Court {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String?      @map("organization_id") @db.Uuid
  name           String
  type           CourtType
  surface        CourtSurface
  resourceType   ResourceType @default(cancha) @map("resource_type")
  status         CourtStatus  @default(active)
  hourlyRate     Decimal      @default(0) @map("hourly_rate") @db.Decimal(10, 2)
  imageUrl       String?      @map("image_url")
  notes          String?
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization     Organization?     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bookings         Booking[]
  bookingWaitlist  BookingWaitlist[]
  trainingSessions TrainingSession[]
  trainingGroups   TrainingGroup[]
  tournamentMatches TournamentMatch[]

  @@map("courts")
}

model Equipment {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String?  @map("organization_id") @db.Uuid
  name           String
  category       String
  quantity       Int      @default(0)
  condition      String   @default("good")
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("equipment")
}

// ─────────────────────────────────────────────
// MÓDULO 2 — Reservas
// ─────────────────────────────────────────────

model Booking {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String?       @map("organization_id") @db.Uuid
  courtId         String?       @map("court_id") @db.Uuid  // assigned by admin at confirmation
  coachId         String?       @map("coach_id") @db.Uuid  // booking priority: coach availability
  playerId        String?       @map("player_id") @db.Uuid
  groupId         String?       @map("group_id") @db.Uuid
  createdBy       String        @map("created_by") @db.Uuid
  sessionId       String?       @map("session_id") @db.Uuid
  startTime       DateTime      @map("start_time") @db.Timestamptz(6)
  endTime         DateTime      @map("end_time") @db.Timestamptz(6)
  status          BookingStatus @default(pending)
  isRecurring     Boolean       @default(false) @map("is_recurring")
  recurrenceRule  String?       @map("recurrence_rule")
  price           Decimal       @default(0) @db.Decimal(10, 2)
  peopleCount     Int           @default(1) @map("people_count") @db.SmallInt
  moduleClasses   Int?          @map("module_classes") @db.SmallInt
  notes           String?
  paymentProofUrl String?       @map("payment_proof_url")
  expiresAt       DateTime?     @map("expires_at") @db.Timestamptz(6)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization       Organization?       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  court              Court?              @relation(fields: [courtId], references: [id])
  coach              Profile?            @relation("CoachBookings", fields: [coachId], references: [id])
  player             Profile?            @relation("PlayerBookings", fields: [playerId], references: [id])
  group              TrainingGroup?      @relation(fields: [groupId], references: [id])
  creator            Profile             @relation("CreatedByBookings", fields: [createdBy], references: [id])
  session            TrainingSession?    @relation(fields: [sessionId], references: [id])
  walletTransactions WalletTransaction[]
  financialTransactions FinancialTransaction[]

  @@index([startTime])
  @@index([startTime, endTime])
  @@index([groupId])
  @@map("bookings")
}

model BookingWaitlist {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courtId      String    @map("court_id") @db.Uuid
  playerId     String    @map("player_id") @db.Uuid
  desiredStart DateTime  @map("desired_start") @db.Timestamptz(6)
  desiredEnd   DateTime  @map("desired_end") @db.Timestamptz(6)
  notifiedAt   DateTime? @map("notified_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  court  Court   @relation(fields: [courtId], references: [id])
  player Profile @relation(fields: [playerId], references: [id])

  @@map("booking_waitlist")
}

// ─────────────────────────────────────────────
// MÓDULO 11 — Biblioteca de Ejercicios
// ─────────────────────────────────────────────

model Exercise {
  id                   String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId       String?       @map("organization_id") @db.Uuid
  createdBy            String        @map("created_by") @db.Uuid
  name                 String
  theme                ExerciseTheme
  objective            String
  level                PadelLevel
  estimatedDurationMin Int           @map("estimated_duration_min")
  materials            String[]      @default([])
  videoUrl             String?       @map("video_url")
  imageUrl             String?       @map("image_url")
  instructions         String?
  isPublished          Boolean       @default(false) @map("is_published")
  createdAt            DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization   Organization?          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator        Profile                @relation(fields: [createdBy], references: [id])
  tagAssignments ExerciseTagAssignment[]
  favorites      ExerciseFavorite[]
  blockExercises SessionBlockExercise[]

  @@map("exercises")
}

model ExerciseTag {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name String @unique

  assignments ExerciseTagAssignment[]

  @@map("exercise_tags")
}

model ExerciseTagAssignment {
  exerciseId String @map("exercise_id") @db.Uuid
  tagId      String @map("tag_id") @db.Uuid

  exercise Exercise    @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  tag      ExerciseTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([exerciseId, tagId])
  @@map("exercise_tag_assignments")
}

model ExerciseFavorite {
  coachId    String   @map("coach_id") @db.Uuid
  exerciseId String   @map("exercise_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  coach    Profile  @relation(fields: [coachId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@id([coachId, exerciseId])
  @@map("exercise_favorites")
}

// ─────────────────────────────────────────────
// MÓDULO 4 — Planificación (Mesociclo → Microciclo → Sesión → Bloques)
// ─────────────────────────────────────────────

model Mesocycle {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String?         @map("organization_id") @db.Uuid
  macrocycleId    String?         @map("macrocycle_id") @db.Uuid
  createdBy       String          @map("created_by") @db.Uuid
  name            String
  generalObjective String?        @map("general_objective")
  level           PadelLevel?
  durationWeeks   Int             @map("duration_weeks")
  status          MesocycleStatus @default(draft)
  startDate       DateTime?       @map("start_date") @db.Date
  endDate         DateTime?       @map("end_date") @db.Date
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization?         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  macrocycle   Macrocycle?           @relation(fields: [macrocycleId], references: [id], onDelete: SetNull)
  creator      Profile               @relation(fields: [createdBy], references: [id])
  assignments  MesocycleAssignment[]
  microcycles  Microcycle[]

  @@map("mesocycles")
}

enum AthleteLevel {
  principiante
  intermedio
  avanzado
}

enum CompetitionType {
  aislada
  agrupada
}

enum PeriodizationModel {
  regular
  concentrado
  dup
}

model Macrocycle {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId     String?             @map("organization_id") @db.Uuid
  createdBy          String              @map("created_by") @db.Uuid
  name               String
  generalObjective   String?             @map("general_objective")
  status             MesocycleStatus     @default(draft)
  athleteLevel       AthleteLevel?       @map("athlete_level")
  competitionType    CompetitionType?    @map("competition_type")
  periodizationModel PeriodizationModel? @map("periodization_model")
  qualities          String[]            @default([])
  startDate          DateTime?           @map("start_date") @db.Date
  endDate            DateTime?           @map("end_date") @db.Date
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator      Profile       @relation(fields: [createdBy], references: [id])
  mesocycles   Mesocycle[]

  @@map("macrocycles")
}

model MesocycleAssignment {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mesocycleId String   @map("mesocycle_id") @db.Uuid
  playerId    String?  @map("player_id") @db.Uuid
  groupId     String?  @map("group_id") @db.Uuid
  assignedBy  String   @map("assigned_by") @db.Uuid
  assignedAt  DateTime @default(now()) @map("assigned_at") @db.Timestamptz(6)

  mesocycle Mesocycle      @relation(fields: [mesocycleId], references: [id])
  player    Profile?       @relation("PlayerAssignments", fields: [playerId], references: [id])
  group     TrainingGroup? @relation(fields: [groupId], references: [id])
  assigner  Profile        @relation("AssignedByAssignments", fields: [assignedBy], references: [id])

  @@map("mesocycle_assignments")
}

enum ContentPhase {
  basico
  especifico
  competitivo
  transicion
}

model Microcycle {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mesocycleId      String        @map("mesocycle_id") @db.Uuid
  weekNumber       Int           @map("week_number")
  weeklyObjective  String?       @map("weekly_objective")
  contentPhase     ContentPhase? @map("content_phase")
  plannedVolume    Int?          @map("planned_volume")
  plannedIntensity Int?          @map("planned_intensity")
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  mesocycle Mesocycle        @relation(fields: [mesocycleId], references: [id], onDelete: Cascade)
  sessions  TrainingSession[]

  @@unique([mesocycleId, weekNumber])
  @@map("microcycles")
}

model TrainingSession {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  microcycleId String        @map("microcycle_id") @db.Uuid
  courtId      String?       @map("court_id") @db.Uuid
  scheduledAt  DateTime      @map("scheduled_at") @db.Timestamptz(6)
  durationMin  Int           @default(90) @map("duration_min")
  status       SessionStatus @default(scheduled)
  coachNotes   String?       @map("coach_notes")
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  microcycle Microcycle     @relation(fields: [microcycleId], references: [id], onDelete: Cascade)
  court      Court?         @relation(fields: [courtId], references: [id])
  blocks     SessionBlock[]
  attendance SessionAttendance[]
  bookings   Booking[]

  @@map("training_sessions")
}

model SessionBlock {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId   String           @map("session_id") @db.Uuid
  blockType   SessionBlockType @map("block_type")
  order       Int
  durationMin Int              @default(20) @map("duration_min")
  notes       String?
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  session   TrainingSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercises SessionBlockExercise[]

