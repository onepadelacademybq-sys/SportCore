  order       Int

  template EvaluationTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  results  EvaluationResult[]

  @@map("evaluation_criteria")
}

model Evaluation {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String?    @map("organization_id") @db.Uuid
  playerId        String     @map("player_id") @db.Uuid
  coachId         String     @map("coach_id") @db.Uuid
  templateId      String?    @map("template_id") @db.Uuid
  title           String
  notes           String?
  overallScore    Decimal?   @map("overall_score") @db.Decimal(4, 2)
  normalizedScore Decimal?   @map("normalized_score") @db.Decimal(5, 2)
  levelAssigned   EvalLevel? @map("level_assigned")
  videoUrl        String?    @map("video_url")
  imageUrl        String?    @map("image_url")
  evaluatedAt     DateTime   @default(now()) @map("evaluated_at") @db.Timestamptz(6)
  isShared        Boolean    @default(false) @map("is_shared")
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization?       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  player       Profile             @relation("PlayerEvaluations", fields: [playerId], references: [id])
  coach        Profile             @relation("CoachEvaluations", fields: [coachId], references: [id])
  template     EvaluationTemplate? @relation(fields: [templateId], references: [id])
  results      EvaluationResult[]

  technicalShots EvalTechnicalShot[]
  tacticalGames  EvalTacticalGame[]
  anthropometric EvalAnthropometric?
  physical       EvalPhysical?

  @@map("evaluations")
}

// ─── Protocolo V3 — tablas especializadas ─────────────────────────────────────

model EvalTechnicalShot {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  evaluationId String   @map("evaluation_id") @db.Uuid
  strokeGroup  String   @map("stroke_group")
  strokeName   String   @map("stroke_name")
  s1           Boolean  @default(false)
  s2           Boolean  @default(false)
  s3           Boolean  @default(false)
  s4           Boolean  @default(false)
  s5           Boolean  @default(false)
  hits         Int?     // GENERATED ALWAYS AS (s1::int+s2::int+s3::int+s4::int+s5::int) STORED
  pct          Decimal? @db.Decimal(5, 2) // GENERATED ALWAYS AS (hits/5*100) STORED
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  evaluation Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  @@unique([evaluationId, strokeName])
  @@map("eval_technical_shots")
}

model EvalTacticalGame {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
