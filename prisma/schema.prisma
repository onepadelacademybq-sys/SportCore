// ─── Libro de finanzas (ledger unificado) ─────────────────────────────────────

enum FinancialTxType {
  income
  expense
}

enum FinancialCategory {
  booking_income  // ingreso: reserva confirmada
  group_income    // ingreso: pago de grupo
  court_cost      // egreso: costo operativo de cancha
  coach_payment   // egreso: pago al entrenador por la clase
  manual_expense  // egreso: registrado a mano (implementos, etc.)
  manual_income   // ingreso: registrado a mano
}

enum AccountType {
  ahorros
  corriente
}

model FinancialTransaction {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String?           @map("organization_id") @db.Uuid
  type           FinancialTxType
  category      FinancialCategory
  amount        Decimal           @db.Decimal(12, 2)
  description   String
  bookingId     String?           @map("booking_id") @db.Uuid
  groupId       String?           @map("group_id") @db.Uuid
  bankAccountId String?           @map("bank_account_id") @db.Uuid
  date          DateTime          @db.Date
  createdBy     String            @map("created_by") @db.Uuid
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization?  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  booking      Booking?       @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  group        TrainingGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  bankAccount  BankAccount?   @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)
  creator      Profile        @relation(fields: [createdBy], references: [id])

  @@index([type, date])
  @@index([category])
  @@index([bookingId])
  @@map("financial_transactions")
}

model BankAccount {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String?     @map("organization_id") @db.Uuid
  name           String      // nombre de la cuenta (alias interno)
  bankName       String      @map("bank_name")
  accountNumber  String?     @map("account_number") // últimos 4 dígitos
  accountType    AccountType @map("account_type")
  currentBalance Decimal     @default(0) @map("current_balance") @db.Decimal(14, 2)
  currency       String      @default("COP")
  isActive       Boolean     @default(true) @map("is_active")
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization?         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transactions FinancialTransaction[]

  @@map("bank_accounts")
}

// ─────────────────────────────────────────────
// MÓDULO 8 — Notificaciones
// ─────────────────────────────────────────────

model Notification {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false) @map("is_read")
  actionUrl String?          @map("action_url")
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@map("notifications")
}

model NotificationPreference {
  userId           String   @id @map("user_id") @db.Uuid
  emailBookings    Boolean  @default(true) @map("email_bookings")
  emailPayments    Boolean  @default(true) @map("email_payments")
  emailSessions    Boolean  @default(true) @map("email_sessions")
  emailEvaluations Boolean  @default(true) @map("email_evaluations")
  emailTournaments Boolean  @default(true) @map("email_tournaments")
  inAppAll         Boolean  @default(true) @map("in_app_all")
  whatsappEnabled  Boolean  @default(true) @map("whatsapp_enabled")
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model Announcement {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String?   @map("organization_id") @db.Uuid
  createdBy      String    @map("created_by") @db.Uuid
  title         String
  body          String
  targetRole    UserRole? @map("target_role")
  targetGroupId String?   @map("target_group_id") @db.Uuid
  sentAt        DateTime? @map("sent_at") @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization?  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator      Profile        @relation(fields: [createdBy], references: [id])
  targetGroup  TrainingGroup? @relation(fields: [targetGroupId], references: [id])

  @@map("announcements")
}

// ─────────────────────────────────────────────
// MÓDULO 10 — Configuración
// ─────────────────────────────────────────────

model AcademySetting {
  id                        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId            String?  @unique @map("organization_id") @db.Uuid
  name                      String   @default("One Padel")
  logoUrl                   String?  @map("logo_url")
  address                   String?
  phone                     String?
  email                     String?
  openingTime               DateTime @default(dbgenerated("'08:00'::time")) @map("opening_time") @db.Time(6)
  closingTime               DateTime @default(dbgenerated("'22:00'::time")) @map("closing_time") @db.Time(6)
  minBookingAdvanceHours    Int      @default(2) @map("min_booking_advance_hours")
  maxBookingAdvanceDays     Int      @default(14) @map("max_booking_advance_days")
  cancellationDeadlineHours Int      @default(24) @map("cancellation_deadline_hours")
  stripePublishableKey      String?  @map("stripe_publishable_key")
  updatedAt                 DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("academy_settings")
}

model AuditLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String
  tableName String   @map("table_name")
  recordId  String?  @map("record_id") @db.Uuid
  oldData   Json?    @map("old_data")
  newData   Json?    @map("new_data")
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("audit_logs")
}

// ─────────────────────────────────────────────
// MÓDULO 13 — Perfil del Entrenador
// ─────────────────────────────────────────────

model CoachProfile {
  coachId           String       @id @map("coach_id") @db.Uuid
  bio               String?
  specialties       String[]     @default([])
  preferredLevels   PadelLevel[] @map("preferred_levels")
  trainingStyle     String?      @map("training_style")
  yearsExperience   Int          @default(0) @map("years_experience")
  languages         String[]     @default(["es"])
  ratingAverage     Decimal?     @map("rating_average") @db.Decimal(3, 2)
  hourlyRateAm      Int          @default(35000) @map("hourly_rate_am")      // L-V 5:00–15:59
  hourlyRatePm      Int          @default(70000) @map("hourly_rate_pm")      // L-V 16:00–22:00
  hourlyRateWeekend Int          @default(60000) @map("hourly_rate_weekend") // Sáb-Dom
  updatedAt         DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  coach          Profile              @relation(fields: [coachId], references: [id], onDelete: Cascade)
  certifications CoachCertification[]
  availability   CoachAvailability[]
  ratings        CoachRating[]

  @@map("coach_profiles")
}

model CoachCertification {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  coachId             String    @map("coach_id") @db.Uuid
  title               String
  issuingOrganization String    @map("issuing_organization")
  obtainedAt          DateTime  @map("obtained_at") @db.Date
  expiresAt           DateTime? @map("expires_at") @db.Date
  documentUrl         String?   @map("document_url")
  isValidated         Boolean   @default(false) @map("is_validated")
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  coach CoachProfile @relation(fields: [coachId], references: [coachId], onDelete: Cascade)

  @@map("coach_certifications")
}

model CoachAvailability {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  coachId   String   @map("coach_id") @db.Uuid
  dayOfWeek Int      @map("day_of_week")
  startTime DateTime @map("start_time") @db.Time(6)
  endTime   DateTime @map("end_time") @db.Time(6)

  coach CoachProfile @relation(fields: [coachId], references: [coachId], onDelete: Cascade)

  @@map("coach_availability")
}

model CoachRating {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  coachId   String   @map("coach_id") @db.Uuid
  playerId  String   @map("player_id") @db.Uuid
  score     Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  coach  CoachProfile @relation(fields: [coachId], references: [coachId])
  player Profile      @relation(fields: [playerId], references: [id])

  @@unique([coachId, playerId])
  @@map("coach_ratings")
}

// ─────────────────────────────────────────────
// MÓDULO CRM — Prospectos, Interacciones, Retención
// ─────────────────────────────────────────────

model Lead {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String?     @map("organization_id") @db.Uuid
  name           String
  phone       String
  whatsapp    String?
  email       String?
  source      LeadSource  @default(web_form)
  status      LeadStatus  @default(new)
  sport       String?
  notes       String?
  lostReason  String?     @map("lost_reason")
  convertedAt DateTime?   @map("converted_at") @db.Timestamptz(6)
  profileId   String?     @map("profile_id") @db.Uuid
  assignedTo  String?     @map("assigned_to") @db.Uuid
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  profile      Profile?      @relation("LeadProfile", fields: [profileId], references: [id], onDelete: SetNull)
  assignee     Profile?      @relation("LeadAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)
  interactions Interaction[]

  @@index([status])
  @@index([source])
  @@map("leads")
}

model Interaction {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profileId   String?         @map("profile_id") @db.Uuid
  leadId      String?         @map("lead_id") @db.Uuid
  type        InteractionType
  summary     String
  waMessageId String?         @map("wa_message_id")
  waStatus    WaMessageStatus? @map("wa_status")
  createdBy   String          @map("created_by") @db.Uuid
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  profile          Profile? @relation("InteractionProfile", fields: [profileId], references: [id], onDelete: Cascade)
  lead             Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdByProfile Profile  @relation("InteractionCreator", fields: [createdBy], references: [id])

  @@index([profileId])
  @@index([leadId])
  @@index([type])
  @@map("interactions")
}

model RetentionScore {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profileId        String          @unique @map("profile_id") @db.Uuid
  score            Int             @default(100)
  status           RetentionStatus @default(active)
  lastClassAt      DateTime?       @map("last_class_at") @db.Timestamptz(6)
  classesThisMonth Int             @default(0) @map("classes_this_month")
  alertSentAt      DateTime?       @map("alert_sent_at") @db.Timestamptz(6)
  updatedAt        DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("retention_scores")
}
