# =============================================================
# SPORTCORE — Configuración para entorno DEMO local
# =============================================================
# 1. Crea un proyecto gratuito en https://supabase.com
# 2. Copia este archivo como .env.local y rellena los valores
# 3. Ejecuta:  npm install && npm run seed:demo
# 4. Inicia:   npm run dev
# 5. Abre:     http://localhost:3000/demo
# =============================================================

# --- Supabase (obtener en Dashboard > Settings > API) --------
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=tu-jwt-secret

# --- Base de datos (obtener en Dashboard > Settings > Database)
# Puerto 6543 = pooler (runtime), 5432 = directo (migraciones)
DATABASE_URL=postgresql://postgres.xxx:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.xxx:password@aws-0-region.pooler.supabase.com:5432/postgres

# --- App ---------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ACADEMY_NAME=One Padel

# --- Stripe (opcional en demo — deja en blanco para omitir) -----
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Sentry (opcional en demo) ----------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# --- Resend (opcional en demo) ----------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=
