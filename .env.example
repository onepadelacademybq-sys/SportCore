# =============================================================
# LYNKOS SPORTCORE — Plantilla de variables de entorno
# Copia este archivo como .env.local y rellena los valores reales
# Los valores aquí son ejemplos o placeholders — nunca datos reales
# =============================================================

# -------------------------------------------------------------
# SUPABASE
# -------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_JWT_SECRET=tu-jwt-secret

# -------------------------------------------------------------
# BASE DE DATOS — Prisma
# -------------------------------------------------------------
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:5432/postgres

# -------------------------------------------------------------
# STRIPE — Pagos SaaS (suscripciones de academias)
# -------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# IDs de precios — crear en Stripe Dashboard > Products
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...

# -------------------------------------------------------------
# RESEND
# -------------------------------------------------------------
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=SportCore <noreply@sportcore.app>

# -------------------------------------------------------------
# APLICACIÓN
# -------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ACADEMY_NAME=One Padel

# -------------------------------------------------------------
# WHATSAPP BUSINESS — Meta Cloud API
# Configurar en: developers.facebook.com → Tu App → WhatsApp → API Setup
# -------------------------------------------------------------
WHATSAPP_PHONE_NUMBER_ID=1234567890
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxx
WHATSAPP_WEBHOOK_VERIFY_TOKEN=mi_token_secreto_aqui
WHATSAPP_BUSINESS_ACCOUNT_ID=9876543210

# -------------------------------------------------------------
# SENTRY (opcional)
# -------------------------------------------------------------
SENTRY_DSN=https://xxx@ooo.ingest.sentry.io/yyy
NEXT_PUBLIC_SENTRY_DSN=https://xxx@ooo.ingest.sentry.io/yyy
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=tu-organizacion-en-sentry
SENTRY_PROJECT=sportcore
